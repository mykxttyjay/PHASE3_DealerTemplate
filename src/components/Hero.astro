---
interface Props {
  badge?: string;
  title: string;
  description: string;
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
  videoUrl?: string;
  minHeight?: string;
}

const {
  badge = "PREMIUM MARKETING SOLUTIONS",
  title,
  description,
  ctaText = "TALK TO OUR TEAM",
  ctaLink = "#",
  imageUrl,
  videoUrl,
  minHeight = "100vh",
} = Astro.props;
---

<section class="hero" style={`min-height: ${minHeight}`}>
  {videoUrl && (
    <video class="hero-video" autoplay muted loop playsinline>
      <source src={videoUrl} type="video/mp4" />
    </video>
  )}
  {imageUrl && !videoUrl && (
    <div class="hero-image-bg" style={`background-image: url('${imageUrl}')`}></div>
  )}
  <div class="hero-overlay"></div>

  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge-wrapper">
        <div class="hero-badge">
          <svg class="badge-star" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {badge}
        </div>
      </div>
      
      <div class="hero-title-wrapper">
        <h1 class="hero-title">
          <span class="title-line">Local Advertising</span>
          <span class="title-line">and Digital Marketing</span>
          <span class="title-line">Pros in Denver</span>
        </h1>
      </div>
      
      <div class="hero-description-wrapper">
        <p class="hero-description">{description}</p>
      </div>
      
      <div class="hero-cta-group">
        <button class="hero-cta hero-cta-primary" data-open-modal>
          <span>{ctaText}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
        <a href="#services" class="hero-cta hero-cta-secondary">
          <span>EXPLORE SERVICES</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(to right, #1a3a52 0%, #1a3a52 50%, #5a8fb3 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    position: relative;
    overflow: hidden;
  }

  .hero-image-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
    z-index: 0;
    image-rendering: high-quality;
    -webkit-font-smoothing: antialiased;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(26, 58, 82, 0.3) 0%, rgba(26, 58, 82, 0.5) 40%, rgba(26, 58, 82, 0.75) 80%, rgba(26, 58, 82, 0.95) 100%);
    z-index: 1;
  }

  .hero-container {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12rem 2rem;
    position: relative;
    z-index: 2;
    min-height: 100%;
  }

  .hero-content {
    color: white;
    z-index: 2;
    max-width: 1000px;
    text-align: center;
  }

  .hero-badge-wrapper {
    margin-bottom: 2.5rem;
    animation: fadeInDown 0.8s ease-out;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.12);
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(15px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
  }

  .hero-badge:hover {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-2px);
  }

  .badge-star {
    flex-shrink: 0;
  }

  .hero-title-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ffffff 0%, #e8f0f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    padding: 0;
  }

  .title-line {
    display: block;
    animation: slideInUp 0.8s ease-out backwards;
  }

  .title-line:nth-child(1) {
    animation-delay: 0.2s;
  }

  .title-line:nth-child(2) {
    animation-delay: 0.4s;
  }

  .title-line:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-description-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 1rem;
    margin-bottom: 2rem;
    animation: fadeIn 0.8s ease-out 0.6s backwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .hero-description {
    font-size: 1.25rem;
    line-height: 1.7;
    opacity: 0.95;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    max-width: 700px;
    font-weight: 400;
  }

  .hero-cta-group {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
    animation: fadeIn 0.8s ease-out 0.8s backwards;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    transition: all 0.4s ease;
    cursor: pointer;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
  }

  .hero-cta::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .hero-cta:hover::before {
    width: 300px;
    height: 300px;
  }

  .hero-cta span {
    position: relative;
    z-index: 1;
  }

  .hero-cta svg {
    position: relative;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  .hero-cta:hover svg {
    transform: translateX(5px);
  }

  .hero-cta-primary {
    background: white;
    color: #1a3a52;
    border: 2px solid white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .hero-cta-primary:hover {
    background: transparent;
    color: white;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
  }

  .hero-cta-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .hero-cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
    transform: translateY(-3px);
  }

  .hero-cta-secondary:hover svg {
    transform: translateY(3px);
  }

  @media (max-width: 1024px) {
    .hero-container {
      padding: 3rem 2rem;
    }

    .hero-cta-group {
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      padding: 0;
    }

    .hero-image-bg {
      background-attachment: scroll;
      background-size: cover;
    }

    .hero-container {
      padding: 8rem 1.5rem 3rem;
      min-height: 100vh;
    }

    .hero-content {
      text-align: center;
    }

    .hero-badge {
      font-size: 0.65rem;
      padding: 0.5rem 1rem;
      gap: 0.5rem;
    }

    .badge-star {
      width: 12px;
      height: 12px;
    }

    .hero-title {
      font-size: 1.75rem;
      line-height: 1.2;
    }

    .hero-description-wrapper {
      margin-bottom: 2rem;
    }

    .hero-description {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .hero-cta-group {
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .hero-cta {
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1.5rem;
      font-size: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .hero-container {
      padding: 7rem 1rem 2.5rem;
    }

    .hero-badge {
      font-size: 0.6rem;
      padding: 0.45rem 0.9rem;
    }

    .hero-title {
      font-size: 1.5rem;
    }

    .hero-description {
      font-size: 0.85rem;
    }

    .hero-cta {
      padding: 0.75rem 1.25rem;
      font-size: 0.75rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const exploreBtn = document.querySelector('.hero-cta-secondary');
    
    exploreBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      const servicesSection = document.getElementById('services');
      
      if (servicesSection) {
        servicesSection.scrollIntoView({ 
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>
