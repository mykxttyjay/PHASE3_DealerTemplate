---
interface Location {
  name: string;
  icon?: string;
}

interface Props {
  title: string;
  subtitle: string;
  mapUrl?: string;
  locations?: Location[];
}

const {
  title,
  subtitle,
  mapUrl,
  locations = [],
} = Astro.props;
---

<section class="locations-section">
  <div class="locations-container">
    <div class="locations-header">
      <h2 class="locations-title">{title}</h2>
      <p class="locations-subtitle" set:html={subtitle}></p>
    </div>

    <div class="locations-content">
      {mapUrl && (
        <div class="locations-map">
          <iframe
            src={mapUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      )}

      {locations.length > 0 && (
        <div class="locations-list">
          <div class="locations-list-header">
            <h3>OUR LOCATIONS</h3>
            <p>Discover the venues in our network.</p>
          </div>
          <div class="locations-items">
            {locations.map((location, index) => (
              <div class="location-item">
                <div class="location-number">
                  {index + 1}
                </div>
                <span class="location-name">{location.name}</span>
                <svg class="location-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .locations-section {
    padding: 5rem 2rem;
    background: #ecf2f8;
  }

  .locations-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .locations-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .locations-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .locations-subtitle {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
    white-space: nowrap;
    font-weight: 500;
  }

  .locations-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  .locations-map {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 450px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 35px rgba(15, 41, 66, 0.2);
    border: 3px solid white;
  }

  .locations-map iframe {
    width: 100%;
    height: 100%;
  }

  .locations-list {
    background: linear-gradient(135deg, #0f2942 0%, #1a3a52 50%, #2d5a7b 100%);
    border: none;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 12px 40px rgba(15, 41, 66, 0.35);
  }

  .locations-list-header {
    margin-bottom: 2rem;
    padding-bottom: 0;
    border-bottom: none;
  }

  .locations-list-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .locations-list-header p {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.5;
    font-weight: 400;
  }

  .locations-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .location-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    transition: all 0.3s ease;
    cursor: pointer;
    background: #ffffff;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.8);
  }

  .location-item:hover {
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 50%, #3a6d8f 100%);
    box-shadow: 0 6px 20px rgba(26, 58, 82, 0.3);
    border-color: transparent;
  }

  .location-item:hover .location-name {
    color: #ffffff;
  }

  .location-item:hover .location-number {
    background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
    color: #1a3a52;
    box-shadow: 0 4px 15px rgba(255, 255, 255, 0.3);
  }

  .location-item:hover .location-arrow {
    color: #ffffff;
  }

  .location-number {
    width: 45px;
    height: 45px;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 50%, #3a6d8f 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(26, 58, 82, 0.25);
  }

  .location-name {
    flex: 1;
    font-size: 1.05rem;
    font-weight: 600;
    color: #0f2942;
    transition: all 0.3s ease;
  }

  .location-arrow {
    flex-shrink: 0;
    color: #3a6d8f;
    transition: all 0.3s ease;
  }

  @media (max-width: 1024px) {
    .locations-content {
      grid-template-columns: 1fr;
    }

    .locations-map {
      height: 350px;
    }
  }

  @media (max-width: 768px) {
    .locations-section {
      padding: 3rem 1rem;
    }

    .locations-header {
      margin-bottom: 2rem;
    }

    .locations-title {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .locations-subtitle {
      font-size: 0.85rem;
      white-space: normal;
      line-height: 1.5;
    }

    .locations-map {
      height: 280px;
      border-radius: 12px;
    }

    .locations-list {
      padding: 1.75rem 1.25rem;
      border-radius: 12px;
    }

    .locations-list-header {
      margin-bottom: 1.5rem;
    }

    .locations-list-header h3 {
      font-size: 1.15rem;
    }

    .locations-list-header p {
      font-size: 0.85rem;
    }

    .locations-items {
      gap: 0.75rem;
    }

    .location-item {
      padding: 0.9rem 1rem;
      gap: 0.75rem;
    }

    .location-number {
      width: 38px;
      height: 38px;
      font-size: 0.95rem;
    }

    .location-name {
      font-size: 0.9rem;
    }

    .location-arrow {
      width: 18px;
      height: 18px;
    }
  }

  @media (max-width: 480px) {
    .locations-section {
      padding: 2.5rem 0.75rem;
    }

    .locations-title {
      font-size: 1.35rem;
    }

    .locations-subtitle {
      font-size: 0.8rem;
    }

    .locations-map {
      height: 250px;
    }

    .locations-list {
      padding: 1.5rem 1rem;
    }

    .locations-list-header h3 {
      font-size: 1.05rem;
    }

    .location-item {
      padding: 0.8rem 0.9rem;
    }

    .location-number {
      width: 35px;
      height: 35px;
      font-size: 0.9rem;
    }

    .location-name {
      font-size: 0.85rem;
    }
  }
</style>
