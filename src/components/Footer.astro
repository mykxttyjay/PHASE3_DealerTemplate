---
interface SocialLink {
  icon: string;
  url: string;
}

interface FooterLink {
  title: string;
  url?: string;
  items?: string[];
}

interface ContactInfo {
  city: string;
  phone: string;
  email: string;
}

interface Props {
  logo?: string;
  description: string;
  socialLinks?: SocialLink[];
  solutions?: FooterLink[];
  billboards?: FooterLink[];
  company?: FooterLink[];
  contact?: ContactInfo;
}

const {
  logo,
  description,
  socialLinks = [],
  solutions = [],
  billboards = [],
  company = [],
  contact,
} = Astro.props;
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-brand">
        {logo && <img src={logo} alt="Logo" class="footer-logo" />}
        <p class="footer-description">{description}</p>
        
        {socialLinks.length > 0 && (
          <div class="social-links">
            {socialLinks.map((link) => (
              <a href={link.url} class="social-link" title={link.icon}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  {link.icon === "instagram" && (
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.322a1.44 1.44 0 110-2.881 1.44 1.44 0 010 2.881z"/>
                  )}
                  {link.icon === "facebook" && (
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  )}
                  {link.icon === "linkedin" && (
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
                  )}
                  {link.icon === "twitter" && (
                    <path d="M23.953 4.57a10 10 0 002.856-3.515 10 10 0 01-2.836.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  )}
                </svg>
              </a>
            ))}
          </div>
        )}
      </div>

      <div class="footer-links">
        {solutions.length > 0 && (
          <div class="footer-column">
            <h4 class="footer-column-title">SOLUTIONS</h4>
            <ul class="footer-list expandable-list">
              {solutions.map((link, index) => (
                <li class={link.items ? "expandable-item" : ""}>
                  {link.items ? (
                    <>
                      <button class="expandable-button" data-expand={`solution-${index}`}>
                        <span>{link.title}</span>
                        <svg class="expand-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                      </button>
                      <ul class="sub-list" data-sublist={`solution-${index}`}>
                        {link.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <a href={link.url}>{link.title}</a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}

        {billboards.length > 0 && (
          <div class="footer-column">
            <h4 class="footer-column-title">INDOOR BILLBOARDS</h4>
            <ul class="footer-list">
              {billboards.map((link) => (
                <li><a href={link.url}>{link.title}</a></li>
              ))}
            </ul>
          </div>
        )}

        {company.length > 0 && (
          <div class="footer-column">
            <h4 class="footer-column-title">COMPANY</h4>
            <ul class="footer-list">
              {company.map((link) => (
                <li><a href={link.url}>{link.title}</a></li>
              ))}
            </ul>
          </div>
        )}

        {contact && (
          <div class="footer-column">
            <h4 class="footer-column-title">CONTACT US</h4>
            <div class="contact-info">
              <p class="contact-item">{contact.city}</p>
              <p class="contact-item"><a href={`tel:${contact.phone}`}>{contact.phone}</a></p>
              <p class="contact-item"><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <div class="footer-legal">
          <a href="#terms">Terms</a>
          <span class="separator">|</span>
          <a href="#privacy">Privacy Policy</a>
        </div>
        <p class="footer-credit">Made by Dealer Template • All rights reserved</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    color: rgba(255, 255, 255, 0.9);
    padding: 4rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .footer-logo {
    height: 80px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .footer-description {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    max-width: 450px;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1.2fr 1.2fr 0.8fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0;
    align-self: start;
  }

  .footer-column-title {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    margin: 0 0 1rem 0;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-list li a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-list li a:hover {
    color: white;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  .contact-item a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-item a:hover {
    color: white;
  }

  .footer-bottom {
    padding: 0rem 0 1rem;
    display: flex;
    align-items: center;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
    width: 100%;
  }

  .footer-legal {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-legal a {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-legal a:hover {
    color: white;
  }

  .separator {
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-credit {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .expandable-list .expandable-item {
    display: flex;
    flex-direction: column;
    margin-bottom: 0.75rem;
  }

  .expandable-list .expandable-item:last-child {
    margin-bottom: 0;
  }

  .expandable-button {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    padding: 0;
    transition: color 0.3s ease;
  }

  .expandable-button:hover {
    color: white;
  }

  .expand-icon {
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  .expandable-button.active .expand-icon {
    transform: rotate(90deg);
  }

  .sub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .sub-list.active {
    max-height: 300px;
    margin-top: 0.75rem;
  }

  .sub-list li {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    padding: 0.4rem 0 0.4rem 1rem;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 2.5rem 1rem 1.5rem;
    }

    .footer-top {
      gap: 2rem;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
    }

    .footer-brand {
      gap: 1.25rem;
    }

    .footer-logo {
      height: 60px;
    }

    .footer-description {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .social-links {
      gap: 0.75rem;
    }

    .social-link {
      width: 36px;
      height: 36px;
    }

    .social-link svg {
      width: 18px;
      height: 18px;
    }

    .footer-links {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-column-title {
      font-size: 0.8rem;
      margin-bottom: 0.9rem;
    }

    .footer-list {
      gap: 0.6rem;
    }

    .footer-list li a {
      font-size: 0.85rem;
    }

    .contact-info {
      gap: 0.6rem;
    }

    .contact-item {
      font-size: 0.85rem;
    }

    .footer-bottom {
      padding: 0 0 0.75rem;
    }

    .footer-bottom-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .footer-legal {
      justify-content: center;
      font-size: 0.8rem;
    }

    .footer-legal a {
      font-size: 0.8rem;
    }

    .footer-credit {
      font-size: 0.8rem;
    }

    .expandable-button {
      font-size: 0.85rem;
    }

    .sub-list li {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding: 2rem 0.75rem 1.25rem;
    }

    .footer-logo {
      height: 50px;
    }

    .footer-description {
      font-size: 0.85rem;
    }

    .footer-links {
      gap: 1.5rem;
    }

    .footer-column-title {
      font-size: 0.75rem;
    }

    .footer-list li a,
    .contact-item {
      font-size: 0.8rem;
    }

    .footer-legal a,
    .footer-credit {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const expandButtons = document.querySelectorAll('.expandable-button');
    
    expandButtons.forEach(button => {
      button.addEventListener('click', () => {
        const expandId = button.getAttribute('data-expand');
        const subList = document.querySelector(`[data-sublist="${expandId}"]`);
        const isActive = button.classList.contains('active');
        
        if (isActive) {
          button.classList.remove('active');
          subList?.classList.remove('active');
        } else {
          button.classList.add('active');
          subList?.classList.add('active');
        }
      });
    });
  });
</script>
