---
interface Service {
  icon: string;
  title: string;
  description: string;
  image?: string;
}

interface Props {
  title: string;
  subtitle: string;
  services: Service[];
  ctaText?: string;
  ctaLink?: string;
}

const {
  title,
  subtitle,
  services,
  ctaText = "EXPLORE OUR DIGITAL MARKETING SERVICES",
  ctaLink = "#services",
} = Astro.props;
---

<section class="services" id="services">
  <div class="services-container">
    <div class="services-header">
      <h2 class="services-title">{title}</h2>
      <p class="services-subtitle" set:html={subtitle}></p>
    </div>

    <div class="carousel-wrapper">
      <button class="carousel-btn carousel-btn-prev" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      
      <div class="services-carousel">
        <div class="carousel-track">
          {services.map((service) => (
            <div class="service-card">
              {service.image && (
                <div class="service-image">
                  <img src={service.image} alt={service.title} />
                </div>
              )}
              <div class="service-content">
                <div class="service-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {service.icon === "billboard" && (
                      <>
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <path d="M16 3h-2v4h2V3z"></path>
                        <path d="M10 3H8v4h2V3z"></path>
                      </>
                    )}
                    {service.icon === "social" && (
                      <>
                        <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
                      </>
                    )}
                    {service.icon === "website" && (
                      <>
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                      </>
                    )}
                    {service.icon === "leads" && (
                      <>
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
                      </>
                    )}
                    {service.icon === "people" && (
                      <>
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </>
                    )}
                    {service.icon === "engagement" && (
                      <>
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                        <line x1="9" y1="9" x2="9.01" y2="9"></line>
                        <line x1="15" y1="9" x2="15.01" y2="9"></line>
                      </>
                    )}
                    {service.icon === "brand" && (
                      <>
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                        <line x1="7" y1="7" x2="7.01" y2="7"></line>
                      </>
                    )}
                    {service.icon === "journey" && (
                      <>
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                      </>
                    )}
                  </svg>
                </div>
                <h3 class="service-title">{service.title}</h3>
                <p class="service-description">{service.description}</p>
              </div>
            </div>
          ))}
          {services.map((service) => (
            <div class="service-card">
              {service.image && (
                <div class="service-image">
                  <img src={service.image} alt={service.title} />
                </div>
              )}
              <div class="service-content">
                <div class="service-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {service.icon === "billboard" && (
                      <>
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <path d="M16 3h-2v4h2V3z"></path>
                        <path d="M10 3H8v4h2V3z"></path>
                      </>
                    )}
                    {service.icon === "social" && (
                      <>
                        <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
                      </>
                    )}
                    {service.icon === "website" && (
                      <>
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                      </>
                    )}
                    {service.icon === "leads" && (
                      <>
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
                      </>
                    )}
                    {service.icon === "people" && (
                      <>
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </>
                    )}
                    {service.icon === "engagement" && (
                      <>
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                        <line x1="9" y1="9" x2="9.01" y2="9"></line>
                        <line x1="15" y1="9" x2="15.01" y2="9"></line>
                      </>
                    )}
                    {service.icon === "brand" && (
                      <>
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                        <line x1="7" y1="7" x2="7.01" y2="7"></line>
                      </>
                    )}
                    {service.icon === "journey" && (
                      <>
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                      </>
                    )}
                  </svg>
                </div>
                <h3 class="service-title">{service.title}</h3>
                <p class="service-description">{service.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <button class="carousel-btn carousel-btn-next" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <div class="carousel-dots"></div>
  </div>
</section>

<style>
  .services {
    padding: 6rem 2rem 3rem;
    background: #dbedf4;
    position: relative;
    overflow: hidden;
  }
  
  .services-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .services-header {
    text-align: center;
    margin-bottom: 2rem;
    animation: fadeInUp 0.8s ease-out;
  }

  .services-title {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 0.1rem;
    letter-spacing: -0.01em;
    position: relative;
    display: inline-block;
  }

  .services-subtitle {
    font-size: 1.1rem;
    color: #555;
    line-height: 1.8;
    max-width: 900px;
    margin: 1rem auto 0;
    font-weight: 500;
  }

  .carousel-wrapper {
    position: relative;
    margin-bottom: 3rem;
  }

  .services-carousel {
    overflow: hidden;
    padding: 1rem 0;
  }

  .carousel-track {
    display: flex;
    gap: 2rem;
    transition: transform 0.8s ease;
  }

  .service-card {
    flex: 0 0 calc(25% - 1.5rem);
    min-width: calc(25% - 1.5rem);
    background: white;
    border-radius: 12px;
    border: 1px solid #d1d5db;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    height: 480px;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 2px solid #1a3a52;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
    color: #1a3a52;
  }

  .carousel-btn:hover {
    background: #1a3a52;
    color: white;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.3);
  }

  .carousel-btn-prev {
    left: -25px;
  }

  .carousel-btn-next {
    right: -25px;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .carousel-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #ffffff;
    border: 3px solid #1a3a52;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .carousel-dot:hover {
    background: #1a3a52;
    transform: scale(1.3);
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.3);
  }

  .carousel-dot.active {
    background: #1a3a52;
    width: 45px;
    border-radius: 7px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.4);
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(26, 58, 82, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .service-card:hover {
    border-color: #1a3a52;
  }

  .service-image {
    width: 100%;
    height: 180px;
    overflow: hidden;
    position: relative;
    z-index: 1;
    margin: 0;
    border-radius: 16px 16px 0 0;
    flex-shrink: 0;
  }

  .service-image::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(26, 58, 82, 0.1) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .service-card:hover .service-image::after {
    opacity: 1;
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .service-card:hover .service-image img {
    transform: scale(1.1);
  }

  .service-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    z-index: 1;
    flex: 1;
  }

  .service-icon {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1.2rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
    flex-shrink: 0;
  }
  
  .service-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-height: 2.4rem;
  }

  .service-description {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  @media (max-width: 1200px) {
    .carousel-btn-prev {
      left: -50px;
    }

    .carousel-btn-next {
      right: -50px;
    }
  }

  @media (max-width: 1024px) {
    .services {
      padding: 4rem 1.5rem 2.5rem;
    }

    .carousel-wrapper {
      padding: 0 0.5rem;
    }

    .service-card {
      flex: 0 0 calc(50% - 1rem);
      min-width: calc(50% - 1rem);
      height: 460px;
    }

    .carousel-btn-prev {
      left: -15px;
    }

    .carousel-btn-next {
      right: -15px;
    }

    .carousel-btn {
      width: 45px;
      height: 45px;
    }

    .carousel-btn svg {
      width: 22px;
      height: 22px;
    }

    .service-image {
      height: 160px;
    }

    .service-content {
      padding: 1.75rem;
    }

    .service-icon {
      width: 60px;
      height: 60px;
      margin-bottom: 1rem;
    }

    .service-icon svg {
      width: 28px;
      height: 28px;
    }

    .service-title {
      font-size: 1.05rem;
      min-height: 2.1rem;
      margin-bottom: 0.7rem;
    }

    .service-description {
      font-size: 0.85rem;
      line-height: 1.55;
    }

    .carousel-dots {
      margin-top: 2rem;
    }

    .carousel-dot {
      width: 10px;
      height: 10px;
    }

    .carousel-dot.active {
      width: 35px;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 3rem 1rem;
    }

    .services::before,
    .services::after {
      display: none;
    }

    .services-header {
      margin-bottom: 2rem;
    }

    .services-title {
      font-size: 1.6rem;
      margin-bottom: 1rem;
    }

    .services-subtitle {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .carousel-wrapper {
      margin-bottom: 1.5rem;
      padding: 0 0.5rem;
    }

    .service-card {
      flex: 0 0 100%;
      min-width: 100%;
      height: auto;
      min-height: 400px;
    }

    .carousel-btn {
      width: 36px;
      height: 36px;
    }

    .carousel-btn svg {
      width: 20px;
      height: 20px;
    }

    .carousel-btn-prev {
      left: -5px;
    }

    .carousel-btn-next {
      right: -5px;
    }

    .service-image {
      height: 140px;
      border-radius: 12px 12px 0 0;
    }

    .service-content {
      padding: 1.25rem;
    }

    .service-icon {
      width: 55px;
      height: 55px;
      margin-bottom: 0.9rem;
    }

    .service-icon svg {
      width: 26px;
      height: 26px;
    }

    .service-title {
      font-size: 0.95rem;
      min-height: auto;
      margin-bottom: 0.6rem;
      line-height: 1.3;
    }

    .service-description {
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .carousel-dots {
      margin-top: 1.5rem;
      gap: 0.6rem;
    }

    .carousel-dot {
      width: 10px;
      height: 10px;
    }

    .carousel-dot.active {
      width: 32px;
    }
  }

  @media (max-width: 480px) {
    .services {
      padding: 2.5rem 0.75rem;
    }

    .services-title {
      font-size: 1.4rem;
    }

    .services-subtitle {
      font-size: 0.85rem;
    }

    .service-card {
      min-height: 380px;
    }

    .service-image {
      height: 130px;
    }

    .service-content {
      padding: 1rem;
    }

    .service-icon {
      width: 50px;
      height: 50px;
    }

    .service-title {
      font-size: 0.9rem;
    }

    .service-description {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('.carousel-track') as HTMLElement;
    const prevBtn = document.querySelector('.carousel-btn-prev') as HTMLButtonElement;
    const nextBtn = document.querySelector('.carousel-btn-next') as HTMLButtonElement;
    const dotsContainer = document.querySelector('.carousel-dots') as HTMLElement;
    const cards = document.querySelectorAll('.service-card');
    
    let currentIndex = 0;
    
    function getCardsPerView() {
      if (window.innerWidth <= 768) return 1;
      if (window.innerWidth <= 1024) return 2;
      return 4;
    }
    
    let cardsPerView = getCardsPerView();
    const totalCards = cards.length / 2; 
    let maxIndex = Math.max(0, totalCards - cardsPerView);
    let autoSlideInterval: number;
    let isTransitioning = false;
    
    function createDots() {
      dotsContainer.innerHTML = '';
      maxIndex = Math.max(0, totalCards - cardsPerView);
      const numDots = maxIndex + 1;
      
      console.log(`Creating ${numDots} dots for carousel`);
      
      for (let i = 0; i < numDots; i++) {
        const dot = document.createElement('button');
        dot.classList.add('carousel-dot');
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.setAttribute('type', 'button');
        if (i === 0) dot.classList.add('active');
        dot.addEventListener('click', () => {
          console.log(`Clicked dot ${i}`);
          goToSlide(i);
        });
        dotsContainer.appendChild(dot);
      }
      
      console.log(`Dots created: ${dotsContainer.children.length}`);
    }
    
    createDots();
    
    function updateCarousel(smooth = true) {
      const cardWidth = (track.children[0] as HTMLElement).offsetWidth;
      const gap = window.innerWidth <= 768 ? 32 : 32;
      const offset = -(currentIndex * (cardWidth + gap));
      
      if (!smooth) {
        track.style.transition = 'none';
      } else {
        track.style.transition = 'transform 0.8s ease';
      }
      
      track.style.transform = `translateX(${offset}px)`;
      
      const allDots = document.querySelectorAll('.carousel-dot');
      allDots.forEach((dot, index) => {
        dot.classList.toggle('active', index === currentIndex);
      });
      
      prevBtn.disabled = false;
      nextBtn.disabled = false;
    }
    
    function goToSlide(index: number) {
      if (isTransitioning) return;
      currentIndex = index;
      updateCarousel();
      resetAutoSlide();
    }
    
    function nextSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      updateCarousel();
      
      setTimeout(() => {
        if (currentIndex >= totalCards) {
          currentIndex = 0;
          updateCarousel(false);
        }
        isTransitioning = false;
      }, 800);
    }
    
    function prevSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      
      if (currentIndex === 0) {
        currentIndex = totalCards;
        updateCarousel(false);
        setTimeout(() => {
          currentIndex--;
          updateCarousel();
          setTimeout(() => {
            isTransitioning = false;
          }, 800);
        }, 50);
      } else {
        currentIndex--;
        updateCarousel();
        setTimeout(() => {
          isTransitioning = false;
        }, 800);
      }
      resetAutoSlide();
    }
    
    function startAutoSlide() {
      autoSlideInterval = window.setInterval(() => {
        nextSlide();
      }, 3000);
    }
    
    function stopAutoSlide() {
      clearInterval(autoSlideInterval);
    }
    
    function resetAutoSlide() {
      stopAutoSlide();
      startAutoSlide();
    }
    
    prevBtn.addEventListener('click', prevSlide);
    nextBtn.addEventListener('click', () => {
      nextSlide();
      resetAutoSlide();
    });
    
    const carouselWrapper = document.querySelector('.carousel-wrapper') as HTMLElement;
    carouselWrapper.addEventListener('mouseenter', stopAutoSlide);
    carouselWrapper.addEventListener('mouseleave', startAutoSlide);
    
    let resizeTimer: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        cardsPerView = getCardsPerView();
        maxIndex = Math.max(0, totalCards - cardsPerView);
        currentIndex = 0;
        createDots();
        updateCarousel(false);
        resetAutoSlide();
      }, 250);
    });
    
    updateCarousel(false);
    startAutoSlide();
  });
</script>
