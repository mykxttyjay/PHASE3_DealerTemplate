---
interface Props {
  logo?: string;
  navItems?: Array<{ label: string; href: string }>;
}

const {
  logo = "/dealer-logo.jpg",
  navItems = [
    { label: "Home", href: "/" },
    { label: "About Us", href: "/#" },
    { label: "Indoor Billboards", href: "/#" },
    { label: "Solutions", href: "/#" },
    { label: "Contact Us", href: "/#" },
  ],
} = Astro.props;
---

<header class="header" id="header">
  <div class="header-container">
    <div class="logo-wrapper">
      <img src={logo} alt="Logo" class="logo" />
    </div>
    <nav class="nav">
      {navItems.map((item, index) => (
        item.label === "Contact Us" ? (
          <a href={item.href} class="nav-link nav-link-button">{item.label}</a>
        ) : (
          <a href={item.href} class="nav-link">
            <span class="nav-link-text">{item.label}</span>
            <span class="nav-link-underline"></span>
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  let lastScrollTop = 0;
  const header = document.getElementById('header');

  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY || document.documentElement.scrollTop;

    if (scrollTop > 100) {
      // Scrolling down
      if (scrollTop > lastScrollTop) {
        header?.classList.add('hide');
        header?.classList.remove('show');
      }
      // Scrolling up
      else {
        header?.classList.remove('hide');
        header?.classList.add('show');
      }
    } else {
      // At top of page
      header?.classList.remove('hide');
      header?.classList.remove('show');
    }

    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
  });
</script>

<style>
  .header {
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    padding: 1.25rem 2rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(26, 58, 82, 0.1);
    transition: all 0.3s ease;
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    animation: slideInLeft 0.6s ease-out;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .logo {
    height: 45px;
    width: auto;
    transition: transform 0.3s ease;
  }

  .logo:hover {
    transform: scale(1.05);
  }

  .nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    margin-left: auto;
  }

  .nav-link {
    text-decoration: none;
    color: #1a3a52;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    animation: slideInDown 0.6s ease-out;
    animation-fill-mode: both;
    letter-spacing: 0.02em;
  }

  .nav-link:nth-child(1) { animation-delay: 0.1s; }
  .nav-link:nth-child(2) { animation-delay: 0.2s; }
  .nav-link:nth-child(3) { animation-delay: 0.3s; }
  .nav-link:nth-child(4) { animation-delay: 0.4s; }
  .nav-link:nth-child(5) { animation-delay: 0.5s; }

  @keyframes slideInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-link-text {
    position: relative;
    z-index: 1;
  }

  .nav-link:hover {
    color: #2d5a7b;
  }

  .nav-link-underline {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, #1a3a52 0%, #2d5a7b 100%);
    transition: width 0.3s ease;
    border-radius: 2px;
  }

  .nav-link:hover .nav-link-underline {
    width: 100%;
  }

  .nav-link-button {
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    color: white !important;
    padding: 0.65rem 1.5rem;
    border-radius: 4px;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
    flex-direction: row;
    gap: 0;
  }

  .nav-link-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(26, 58, 82, 0.3);
    background: linear-gradient(135deg, #2d5a7b 0%, #1a3a52 100%);
  }

  .nav-link-button .nav-link-underline {
    display: none;
  }

  @media (max-width: 1024px) {
    .nav {
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .header {
      padding: 1rem;
    }

    .header-container {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo-wrapper {
      width: 100%;
      justify-content: center;
    }

    .nav {
      width: 100%;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      order: 3;
    }

    .nav-link {
      font-size: 0.8rem;
    }

    .nav-link-button {
      padding: 0.6rem 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>
