---
interface Solution {
  icon: string;
  title: string;
  description: string;
  image?: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  imageUrl?: string;
  solutions?: Solution[];
  ctaText?: string;
  ctaLink?: string;
}

const {
  badge = "FEATURED",
  title,
  description,
  imageUrl,
  solutions = [],
  ctaText = "VIEW ALL MARKETING SOLUTIONS",
  ctaLink = "#solutions",
} = Astro.props;
---

<section class="featured">
  <div class="featured-container">
    <div class="featured-header">
      <div class="featured-badge">
        <svg class="badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {badge}
      </div>
      <h2 class="featured-title">{title}</h2>
      <p class="featured-description" set:html={description}></p>
    </div>

    {imageUrl && (
      <div class="featured-image-wrapper">
        <img src={imageUrl} alt={title} class="featured-image" />
        <div class="image-overlay"></div>
      </div>
    )}

    {solutions.length > 0 && (
      <>
        <div class="solutions-grid" id="solutions-grid">
          {solutions.map((solution, index) => (
            <div class="solution-card" data-index={index} style={`animation-delay: ${index * 0.1}s`}>
              {solution.image && (
                <div class="solution-image">
                  <img src={solution.image} alt={solution.title} />
                </div>
              )}
              <div class="solution-content">
                <div class="solution-icon">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {solution.icon === "google" && (
                      <>
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 6v12M6 12h12"></path>
                      </>
                    )}
                    {solution.icon === "website" && (
                      <>
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                        <path d="M2 17h20"></path>
                      </>
                    )}
                    {solution.icon === "social" && (
                      <>
                        <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
                      </>
                    )}
                    {solution.icon === "ppc" && (
                      <>
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                      </>
                    )}
                    {solution.icon === "screen" && (
                      <>
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                        <line x1="8" y1="21" x2="16" y2="21"></line>
                        <line x1="12" y1="17" x2="12" y2="21"></line>
                      </>
                    )}
                    {solution.icon === "socialads" && (
                      <>
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <polyline points="17 2 12 7 7 2"></polyline>
                      </>
                    )}
                    {solution.icon === "geofencing" && (
                      <>
                        <circle cx="12" cy="12" r="10"></circle>
                        <circle cx="12" cy="12" r="6"></circle>
                        <circle cx="12" cy="12" r="2"></circle>
                      </>
                    )}
                    {solution.icon === "tv" && (
                      <>
                        <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect>
                        <polyline points="17 2 12 7 7 2"></polyline>
                      </>
                    )}
                    {solution.icon === "audio" && (
                      <>
                        <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
                      </>
                    )}
                    {solution.icon === "design" && (
                      <>
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>
                        <circle cx="6.5" cy="11.5" r="1.5"></circle>
                        <circle cx="9.5" cy="7.5" r="1.5"></circle>
                        <circle cx="14.5" cy="7.5" r="1.5"></circle>
                        <circle cx="17.5" cy="11.5" r="1.5"></circle>
                      </>
                    )}
                  </svg>
                </div>
                <h3 class="solution-title">{solution.title}</h3>
                <p class="solution-description">{solution.description}</p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}

    <div class="featured-action">
      <button class="featured-button" id="toggle-solutions">
        <span class="button-text">{ctaText}</span>
        <svg class="button-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .featured {
    padding: 6rem 2rem;
    background: #dbedf4;
    position: relative;
    overflow: hidden;
  }

  .featured::before,
  .featured::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
    pointer-events: none;
  }

  .featured::before {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(26, 58, 82, 0.3) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .featured::after {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(26, 58, 82, 0.2) 0%, transparent 70%);
    bottom: -50px;
    left: -50px;
    animation: float 10s ease-in-out infinite reverse;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(30px);
    }
  }

  .featured-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .featured-header {
    margin-bottom: 3.5rem;
    text-align: left;
    animation: fadeInUp 0.8s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.7rem 1.2rem;
    background: rgba(26, 58, 82, 0.08);
    border: 2px solid rgba(26, 58, 82, 0.25);
    border-radius: 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #1a3a52;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .badge-icon {
    flex-shrink: 0;
  }

  .featured-title {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .featured-description {
    font-size: 1.1rem;
    color: #555;
    line-height: 1.8;
    max-width: 1205px;
    font-weight: 500;
  }

  .featured-image-wrapper {
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 4rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
    position: relative;
    animation: fadeInUp 0.8s ease-out 0.1s both;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(26, 58, 82, 0.05) 0%, transparent 100%);
    pointer-events: none;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-bottom: 4rem;
    position: relative;
  }

  .solutions-grid .solution-card:nth-last-child(2):nth-child(4n + 1) {
    grid-column: 2 / 3;
  }

  .solutions-grid .solution-card:nth-last-child(1):nth-child(4n + 2) {
    grid-column: 3 / 4;
  }

  .solutions-grid.collapsed .solution-card[data-index]:nth-child(n+5) {
    display: none;
  }

  .solution-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    border: 1px solid #d1d5db;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    animation: fadeInUp 0.8s ease-out;
    animation-fill-mode: both;
    position: relative;
    overflow: hidden;
  }

  .solution-card:hover {
    box-shadow: 0 12px 40px rgba(26, 58, 82, 0.15);
    border-color: #1a3a52;
  }

  .solution-image {
    width: calc(100% + 5rem);
    height: 160px;
    margin: -2.5rem -2.5rem 1.5rem -2.5rem;
    overflow: hidden;
    position: relative;
  }

  .solution-image::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(26, 58, 82, 0.1) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .solution-card:hover .solution-image::after {
    opacity: 1;
  }

  .solution-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .solution-card:hover .solution-image img {
    transform: scale(1.05);
  }

  .solution-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .solution-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
    position: relative;
    z-index: 1;
  }

  .solution-icon svg {
    stroke: white;
  }

  .solution-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .solution-description {
    font-size: 1rem;
    color: #666;
    line-height: 1.7;
    margin: 0;
  }

  .featured-action {
    display: flex;
    justify-content: center;
    animation: fadeInUp 0.8s ease-out 0.3s both;
  }

  .featured-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 3rem;
    background: white;
    color: #1a3a52;
    text-decoration: none;
    border: 2px solid #1a3a52;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    text-transform: uppercase;
    box-shadow: none;
    cursor: pointer;
    font-family: inherit;
  }

  .featured-button:hover {
    background: #1a3a52;
    color: white;
    border-color: #1a3a52;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 58, 82, 0.25);
  }

  .button-icon {
    transition: transform 0.3s ease;
  }

  .featured-button.expanded .button-icon {
    transform: rotate(180deg);
  }

  @media (max-width: 768px) {
    .featured {
      padding: 3rem 1rem;
    }

    .featured::before,
    .featured::after {
      display: none;
    }

    .featured-header {
      margin-bottom: 2rem;
      text-align: center;
    }

    .featured-badge {
      font-size: 0.7rem;
      padding: 0.5rem 1rem;
      margin-bottom: 1rem;
    }

    .featured-title {
      font-size: 1.6rem;
      margin-bottom: 1rem;
    }

    .featured-description {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .featured-image-wrapper {
      height: 220px;
      margin-bottom: 2rem;
      border-radius: 8px;
    }

    .solutions-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }

    .solutions-grid .solution-card:nth-last-child(2):nth-child(4n + 1),
    .solutions-grid .solution-card:nth-last-child(1):nth-child(4n + 2) {
      grid-column: auto;
    }

    .solution-card {
      padding: 1.75rem;
    }

    .solution-icon {
      width: 55px;
      height: 55px;
      margin-bottom: 1rem;
    }

    .solution-icon svg {
      width: 24px;
      height: 24px;
    }

    .solution-title {
      font-size: 0.95rem;
      letter-spacing: 0.05em;
    }

    .solution-description {
      font-size: 0.85rem;
      line-height: 1.6;
    }

    .featured-button {
      padding: 0.85rem 2rem;
      font-size: 0.75rem;
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .featured {
      padding: 2.5rem 0.75rem;
    }

    .featured-title {
      font-size: 1.4rem;
    }

    .featured-description {
      font-size: 0.85rem;
    }

    .featured-image-wrapper {
      height: 200px;
    }

    .solution-card {
      padding: 1.5rem;
    }

    .solution-icon {
      width: 50px;
      height: 50px;
    }

    .solution-title {
      font-size: 0.9rem;
    }

    .solution-description {
      font-size: 0.8rem;
    }

    .featured-button {
      padding: 0.75rem 1.5rem;
      font-size: 0.7rem;
    }
  }
</style>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButton = document.getElementById('toggle-solutions') as HTMLButtonElement;
    const solutionsGrid = document.getElementById('solutions-grid') as HTMLElement;
    const buttonText = toggleButton?.querySelector('.button-text') as HTMLElement;
    
    if (!toggleButton || !solutionsGrid) return;
    
    solutionsGrid.classList.add('collapsed');
    
    toggleButton.addEventListener('click', () => {
      const isCollapsed = solutionsGrid.classList.contains('collapsed');
      
      if (isCollapsed) {
        solutionsGrid.classList.remove('collapsed');
        toggleButton.classList.add('expanded');
        buttonText.textContent = 'SHOW LESS';
      } else {
        solutionsGrid.classList.add('collapsed');
        toggleButton.classList.remove('expanded');
        buttonText.textContent = 'VIEW ALL MARKETING SOLUTIONS';
        
        const featuredSection = document.querySelector('.featured') as HTMLElement;
        if (featuredSection) {
          featuredSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
