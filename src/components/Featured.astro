---
interface Solution {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  imageUrl?: string;
  solutions?: Solution[];
  ctaText?: string;
  ctaLink?: string;
}

const {
  badge = "FEATURED",
  title,
  description,
  imageUrl,
  solutions = [],
  ctaText = "VIEW ALL MARKETING SOLUTIONS",
  ctaLink = "#solutions",
} = Astro.props;
---

<section class="featured">
  <div class="featured-container">
    <div class="featured-header">
      <div class="featured-badge">
        <svg class="badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {badge}
      </div>
      <h2 class="featured-title">{title}</h2>
      <p class="featured-description" set:html={description}></p>
    </div>

    {imageUrl && (
      <div class="featured-image-wrapper">
        <img src={imageUrl} alt={title} class="featured-image" />
        <div class="image-overlay"></div>
      </div>
    )}

    {solutions.length > 0 && (
      <div class="solutions-grid">
        {solutions.map((solution, index) => (
          <div class="solution-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="solution-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                {solution.icon === "google" && (
                  <>
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 6v12M6 12h12"></path>
                  </>
                )}
                {solution.icon === "website" && (
                  <>
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                    <path d="M2 17h20"></path>
                  </>
                )}
                {solution.icon === "social" && (
                  <>
                    <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7"></path>
                  </>
                )}
                {solution.icon === "ppc" && (
                  <>
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"></path>
                  </>
                )}
              </svg>
            </div>
            <div class="solution-content">
              <h3 class="solution-title">{solution.title}</h3>
              <p class="solution-description">{solution.description}</p>
            </div>
          </div>
        ))}
      </div>
    )}

    <div class="featured-action">
      <a href={ctaLink} class="featured-button">{ctaText}</a>
    </div>
  </div>
</section>

<style>
  .featured {
    padding: 6rem 2rem;
    background: linear-gradient(135deg, #e8f4f8 0%, #d4e9f2 100%);
    position: relative;
    overflow: hidden;
  }

  .featured::before,
  .featured::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
    pointer-events: none;
  }

  .featured::before {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(26, 58, 82, 0.3) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .featured::after {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(26, 58, 82, 0.2) 0%, transparent 70%);
    bottom: -50px;
    left: -50px;
    animation: float 10s ease-in-out infinite reverse;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(30px);
    }
  }

  .featured-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .featured-header {
    margin-bottom: 3.5rem;
    text-align: left;
    animation: fadeInUp 0.8s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.7rem 1.2rem;
    background: rgba(26, 58, 82, 0.08);
    border: 2px solid rgba(26, 58, 82, 0.25);
    border-radius: 16px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #1a3a52;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .badge-icon {
    flex-shrink: 0;
  }

  .featured-title {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .featured-description {
    font-size: 1.1rem;
    color: #555;
    line-height: 1.8;
    max-width: 1205px;
    font-weight: 500;
  }

  .featured-image-wrapper {
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 4rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
    position: relative;
    animation: fadeInUp 0.8s ease-out 0.1s both;
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(26, 58, 82, 0.05) 0%, transparent 100%);
    pointer-events: none;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .solution-card {
    background: white;
    padding: 2.5rem;
    border-radius: 12px;
    border: 1px solid #e8e8e8;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    animation: fadeInUp 0.8s ease-out;
    animation-fill-mode: both;
    position: relative;
    overflow: hidden;
  }

  .solution-card:hover {
    box-shadow: 0 12px 40px rgba(26, 58, 82, 0.15);
    border-color: #1a3a52;
  }

  .solution-icon {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1.5rem;
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
    position: relative;
    z-index: 1;
  }

  .solution-icon svg {
    stroke: white;
  }

  .solution-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .solution-description {
    font-size: 1rem;
    color: #666;
    line-height: 1.7;
    margin: 0;
  }

  .featured-action {
    display: flex;
    justify-content: center;
    animation: fadeInUp 0.8s ease-out 0.3s both;
  }

  .featured-button {
    display: inline-block;
    padding: 1rem 3rem;
    background: white;
    color: #1a3a52;
    text-decoration: none;
    border: 2px solid #1a3a52;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    text-transform: uppercase;
    box-shadow: none;
  }

  .featured-button:hover {
    background: #1a3a52;
    color: white;
    border-color: #1a3a52;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 58, 82, 0.25);
  }

  @media (max-width: 768px) {
    .featured {
      padding: 4rem 1.5rem;
    }

    .featured-header {
      margin-bottom: 2.5rem;
    }

    .featured-badge {
      font-size: 0.75rem;
      padding: 0.5rem 1rem;
      margin-bottom: 1rem;
    }

    .featured-title {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }

    .featured-description {
      font-size: 0.95rem;
    }

    .featured-image-wrapper {
      height: 250px;
      margin-bottom: 2.5rem;
    }

    .solutions-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .solution-card {
      padding: 2rem;
    }

    .solution-icon {
      width: 60px;
      height: 60px;
      margin-bottom: 1rem;
    }

    .solution-title {
      font-size: 1rem;
    }

    .solution-description {
      font-size: 0.9rem;
    }

    .cta-button {
      padding: 0.9rem 2.5rem;
      font-size: 0.85rem;
    }
  }
</style>
