---
interface Props {
  badge?: string;
  title: string;
  description: string;
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
}

const {
  badge = "YOUR TRUSTED DENVER MARKETING PARTNERS",
  title,
  description,
  ctaText = "GET STARTED TODAY",
  ctaLink = "#contact",
  imageUrl,
} = Astro.props;
---

<section class="why-choose-us">
  <div class="why-container">
    <div class="why-content">
      <div class="why-badge">
        <svg class="badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {badge}
      </div>
      <h2 class="why-title">{title}</h2>
      <p class="why-description" set:html={description}></p>
      <a href={ctaLink} class="why-cta">
        <span>{ctaText}</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
    
    {imageUrl && (
      <div class="why-image-wrapper">
        <div class="why-image">
          <img src={imageUrl} alt={title} />
        </div>
        <div class="image-decoration"></div>
      </div>
    )}
  </div>
</section>

<style>
  .why-choose-us {
    padding: 6rem 2rem;
    background: #ecf2f8;
    position: relative;
    overflow: hidden;
  }

  .why-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .why-badge {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    padding: 0.7rem 1.2rem;
    background: rgba(26, 58, 82, 0.06);
    border: 2px solid rgba(26, 58, 82, 0.2);
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #1a3a52;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .badge-icon {
    flex-shrink: 0;
  }

  .why-title {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .why-description {
    font-size: 1.01rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .why-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 2.2rem;
    background: #1a3a52;
    color: white;
    text-decoration: none;
    border: 2px solid #1a3a52;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    text-transform: uppercase;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
  }

  .why-cta svg {
    transition: transform 0.3s ease;
  }

  .why-cta:hover {
    background: white;
    color: #1a3a52;
    border-color: #1a3a52;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 58, 82, 0.25);
  }

  .why-cta:hover svg {
    transform: translateX(5px);
  }

  .why-image-wrapper {
    position: relative;
    animation: slideInRight 0.8s ease-out;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .why-image {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    aspect-ratio: 4 / 3;
  }

  .why-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-decoration {
    display: none;
  }

  @media (max-width: 1024px) {
    .why-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .why-image-wrapper {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .why-choose-us {
      padding: 3rem 1rem;
    }

    .why-container {
      gap: 2rem;
    }

    .why-badge {
      font-size: 0.65rem;
      padding: 0.5rem 1rem;
      margin-bottom: 1rem;
    }

    .why-title {
      font-size: 1.6rem;
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .why-description {
      font-size: 0.9rem;
      margin-bottom: 1.75rem;
      line-height: 1.6;
    }

    .why-cta {
      padding: 0.85rem 1.75rem;
      font-size: 0.75rem;
      width: 100%;
      justify-content: center;
    }

    .why-image {
      border-radius: 8px;
      aspect-ratio: 4 / 3;
      min-height: 250px;
    }

    .image-decoration {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .why-choose-us {
      padding: 2.5rem 0.75rem;
    }

    .why-title {
      font-size: 1.4rem;
    }

    .why-description {
      font-size: 0.85rem;
    }

    .why-cta {
      padding: 0.75rem 1.5rem;
      font-size: 0.7rem;
    }

    .why-image {
      min-height: 220px;
    }
  }
</style>
