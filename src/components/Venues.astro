---
interface Props {
  title: string;
  description: string;
  features?: string[];
  ctaText?: string;
  ctaLink?: string;
  imageUrl?: string;
}

const {
  title,
  description,
  features = [],
  ctaText = "VIEW VENUE PARTNERS",
  ctaLink = "#venues",
  imageUrl,
} = Astro.props;
---

<section class="venues">
  <div class="venues-container">
    <div class="venues-content">
      <div class="venues-badge">
        <svg class="badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        PREMIUM VENUE NETWORK
      </div>
      
      <h2 class="venues-title">{title}</h2>
      <p class="venues-description" set:html={description}></p>
      
      {features.length > 0 && (
        <ul class="venues-features">
          {features.map((feature) => (
            <li class="feature-item">
              <span class="feature-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="feature-text">{feature}</span>
            </li>
          ))}
        </ul>
      )}
      
      <a href={ctaLink} class="venues-cta">{ctaText}</a>
    </div>
    
    {imageUrl && (
      <div class="venues-image-wrapper">
        <div class="venues-image">
          <img src={imageUrl} alt="Denver venue billboard" />
        </div>
        <div class="image-decoration"></div>
      </div>
    )}
  </div>
</section>

<style>
  .venues {
    padding: 6rem 2rem;
    background: linear-gradient(135deg, #f5f7fa 0%, #e8f0f7 100%);
    position: relative;
    overflow: hidden;
  }

  .venues-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5.5rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .venues-content {
    animation: slideInLeft 0.8s ease-out;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .venues-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    color: #1a3a52;
    background: rgba(26, 58, 82, 0.08);
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    border: 1px solid rgba(26, 58, 82, 0.15);
  }

  .badge-icon {
    flex-shrink: 0;
  }

  .venues-title {
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 700;
    color: #1a3a52;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .venues-description {
    font-size: 1.03rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .venues-features {
    list-style: none;
    margin-bottom: 2.5rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: 1rem;
    color: #333;
    margin-bottom: 1.2rem;
    font-weight: 500;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    color: white;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature-text {
    flex: 1;
  }

  .venues-cta {
    display: inline-block;
    padding: 0.9rem 2.2rem;
    background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
    color: white;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    text-transform: uppercase;
    box-shadow: 0 4px 15px rgba(26, 58, 82, 0.2);
  }

  .venues-cta:hover {
    background: white;
    color: #1a3a52;
    border-color: #1a3a52;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 58, 82, 0.25);
  }

  .venues-image-wrapper {
    position: relative;
    animation: slideInRight 0.8s ease-out;
  }

  .venues-image {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    aspect-ratio: 4 / 3;
  }

  .venues-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .venues {
      padding: 4rem 1.5rem;
    }

    .venues-container {
      gap: 2rem;
    }

    .venues-badge {
      font-size: 0.75rem;
      padding: 0.5rem 1rem;
      margin-bottom: 1rem;
    }

    .venues-title {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    .venues-description {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    .feature-item {
      font-size: 0.9rem;
      margin-bottom: 0.8rem;
      gap: 0.75rem;
    }

    .feature-icon {
      width: 20px;
      height: 20px;
      margin-top: 1px;
    }

    .venues-cta {
      padding: 0.8rem 1.8rem;
      font-size: 0.8rem;
    }

    .venues-image {
      border-radius: 8px;
    }

    .image-decoration {
      display: none;
    }
  }
</style>
