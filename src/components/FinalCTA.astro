---
interface Props {
  title: string;
  description: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
}

const {
  title,
  description,
  ctaText = "GET STARTED",
  ctaLink = "#contact",
  backgroundImage,
} = Astro.props;
---

<section
  class="final-cta"
  style={backgroundImage ? `background-image: url(${backgroundImage})` : ""}
>
  <div class="final-cta-overlay"></div>
  <div class="final-cta-container">
    <div class="final-cta-content">
      <h2 class="final-cta-title">{title}</h2>
      <p class="final-cta-description">{description}</p>
      <a href={ctaLink} class="final-cta-button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <span>{ctaText}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    padding: 6rem 2rem;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .final-cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26, 58, 82, 0.85) 0%, rgba(45, 90, 123, 0.85) 100%);
    z-index: 1;
  }

  .final-cta-container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .final-cta-content {
    max-width: 900px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    padding: 4.5rem 4rem;
    text-align: center;
    backdrop-filter: blur(10px);
    background: rgba(255, 255, 255, 0.05);
  }

  .final-cta-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .final-cta-description {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .final-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 2.5rem;
    background: white;
    color: #1a3a52;
    text-decoration: none;
    border: 2px solid white;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .final-cta-button svg {
    transition: transform 0.3s ease;
  }

  .final-cta-button:hover {
    background: transparent;
    color: white;
    transform: translateY(-2px);
  }

  .final-cta-button:hover svg {
    transform: scale(1.15);
  }

  @media (max-width: 768px) {
    .final-cta {
      padding: 3rem 1rem;
      min-height: 350px;
      background-attachment: scroll;
    }

    .final-cta-content {
      padding: 2rem 1.5rem;
      border-radius: 12px;
    }

    .final-cta-title {
      font-size: 1.4rem;
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .final-cta-description {
      font-size: 0.9rem;
      margin-bottom: 1.75rem;
      line-height: 1.6;
    }

    .final-cta-button {
      padding: 0.85rem 1.75rem;
      font-size: 0.75rem;
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .final-cta {
      padding: 2.5rem 0.75rem;
      min-height: 320px;
    }

    .final-cta-content {
      padding: 1.75rem 1.25rem;
    }

    .final-cta-title {
      font-size: 1.25rem;
    }

    .final-cta-description {
      font-size: 0.85rem;
    }

    .final-cta-button {
      padding: 0.75rem 1.5rem;
      font-size: 0.7rem;
    }
  }
</style>
